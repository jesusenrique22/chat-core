# Copia este archivo a .env y completa los valores (no subas .env a GitHub)

PORT=4000
MONGODB_URI=mongodb://localhost:27017/chat_multiservicio

# CORS (producción: false en ambos)
CORS_ALLOW_LAN=true
CORS_ALLOW_ALL=false
# CORS_EXTRA_ORIGINS=https://tu-dominio.com,https://otro-dominio.com

# URL pública del servidor (imágenes en /uploads)
# PUBLIC_BASE_URL=https://chat.tudominio.com

# Tamaño máximo de imagen en bytes (default 3 MB)
# UPLOAD_MAX_BYTES=3145728

# URL de la API externa de notificaciones (Sistema de Tickets)
NOTIFICATIONS_API_URL=https://ticketsotravez-1.onrender.com/notifications/ticket
NOTIFICATIONS_API_KEY=tickets_secret_key_2026
