# Copia este archivo a .env o .env.local y completa los valores.
# El backend NO arranca si faltan las variables marcadas como [OBLIGATORIA].

PORT=4000

# --- Obligatorias (sin defaults en runtime) ---
# [OBLIGATORIA]
MONGODB_URI=mongodb://localhost:27017/chat_multiservicio

# [OBLIGATORIA] true | false
CORS_ALLOW_LAN=true
# [OBLIGATORIA] true | false
CORS_ALLOW_ALL=false
# CORS_EXTRA_ORIGINS=https://tu-dominio.com,https://otro-dominio.com

# [OBLIGATORIA] Bucket de imágenes
BUCKET_UPLOAD_URL=https://api-bucket.smart.com.ve/api/imau/upload
# [OBLIGATORIA]
BUCKET_API_KEY=
# [OBLIGATORIA]
BUCKET_FOLDER=ticket_chat

# [OBLIGATORIA] Notificaciones → Sistema de Tickets
NOTIFICATIONS_API_URL=https://ticketsotravez.onrender.com/notifications/ticket
# [OBLIGATORIA]
NOTIFICATIONS_API_KEY=

# --- Opcionales ---
# LOG_LEVEL=info
# PUBLIC_BASE_URL=https://chat.tudominio.com
# UPLOAD_MAX_BYTES=3145728
# JOIN_CHAT_MESSAGE_LIMIT=50
# CORS_CACHE_TTL_MS=300000
# SEND_MESSAGE_MAX_PER_MIN=10
# RATE_LIMIT_INTEGRATIONS=100
# RATE_LIMIT_CONVERSATIONS=60
# RATE_LIMIT_UPLOADS=20
# SOCKET_RECOVERY_MS=30000

# Mongo pool / timeouts (prod defaults: pool 20, selection 10s, socket 45s)
# MONGO_MAX_POOL_SIZE=20
# MONGO_MIN_POOL_SIZE=2
# MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
# MONGO_SOCKET_TIMEOUT_MS=45000
# MONGO_CONNECT_TIMEOUT_MS=10000

# Desarrollo: permitir Mongo en memoria si falla MONGODB_URI (prod: nunca)
# ALLOW_MEMORY_MONGO=true

# Grace period al apagar (pm2 reload / SIGTERM), ms
# SHUTDOWN_TIMEOUT_MS=7000
